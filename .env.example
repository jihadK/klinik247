APP_NAME="Klinik247"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://testapklnk.test

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID
APP_TIMEZONE=Asia/Jakarta

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=10

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# === PostgreSQL Remote (Server Klinik) ===
DB_CONNECTION=pgsql
DB_HOST=103.93.162.70
DB_PORT=5432
DB_DATABASE=klinik
DB_USERNAME=klinik_app
DB_PASSWORD=
DB_SCHEMA=public

# === Session ===
# Driver: file (default), database, redis
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
# PRODUCTION: set true (HTTPS only)
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PATH=/
SESSION_DOMAIN=null

# === Cache ===
CACHE_STORE=file
# CACHE_PREFIX=

# === Queue ===
QUEUE_CONNECTION=sync
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# === Redis (opsional) ===
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# === Mail ===
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@klinik247.id"
MAIL_FROM_NAME="${APP_NAME}"

# === Portal Pasien ===
# Override default kalau perlu
# PORTAL_RATE_LIMIT_ATTEMPTS=5
# PORTAL_RATE_LIMIT_DECAY_MINUTES=15
# PORTAL_SESSION_EXPIRY_MINUTES=30

VITE_APP_NAME="${APP_NAME}"
